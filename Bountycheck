-- [[ WEBHOOK FUNCTION ]]
local HttpService = game:GetService("HttpService")
local Player = game.Players.LocalPlayer

local function updateWebhook(teamName, bountyValue)
    local data = {
        ["embeds"] = {{
            ["title"] = "🔴 TRẠNG THÁI TRỰC TUYẾN - " .. Settings.Admin_Name,
            ["fields"] = {
                {["name"] = "👤 Nhân vật", ["value"] = Player.Name, ["inline"] = true},
                {["name"] = "🚩 Phe", ["value"] = teamName, ["inline"] = true},
                {["name"] = "💰 Bounty/Honor", ["value"] = bountyValue, ["inline"] = false}
            },
            ["color"] = teamName == "Pirates" and 15105570 or 3447003,
            ["footer"] = {["text"] = "Cập nhật lần cuối: " .. os.date("%H:%M:%S")},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    local jsonData = HttpService:JSONEncode(data)
    local request = http_request or request or HttpPost or syn.request
    
    if not lastMsgId then
        -- Lần đầu tiên: Gửi tin nhắn mới
        local response = request({
            Url = baseWebhook,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
        if response.Success then
            local resData = HttpService:JSONDecode(response.Body)
            lastMsgId = resData.id -- Lưu ID tin nhắn lại
        end
    else
        -- Các lần sau: Sửa (PATCH) tin nhắn cũ
        request({
            Url = Settings.Webhook_URL .. "/messages/" .. lastMsgId,
            Method = "PATCH",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end
end

-- [[ MAIN LOOP ]]
spawn(function()
    while true do
        pcall(function()
            local team = Player.Team
            local bounty = Player.leaderstats["Bounty/Honor"].Value
            local teamName = (team and team.Name) or "Đang chọn phe..."
            
            local function formatNumber(n)
                return tostring(n):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
            end

            -- Update UI trong game (Góc phải)
            InfoLabel.Text = string.format("Phe: %s\nBounty: %s\nWebhook: Đang chạy", 
                teamName, formatNumber(bounty))
            
            -- Gửi/Sửa Webhook Discord
            updateWebhook(teamName, formatNumber(bounty))
        end)
        task.wait(Settings.Check_Interval)
    end
end)
